# Must match server BETTER_AUTH_URL (same public origin as /api on your deployment).
# Google Cloud Console authorized redirect URI: {EXPO_PUBLIC_BACKEND}/api/auth/callback/google
EXPO_PUBLIC_BACKEND=https://your-api.example.com

# Optional web origin override when window.location.origin is wrong (tests, SSR).
# EXPO_PUBLIC_APP_URL=

# E2E / MCP (local only)
# TEST_USERNAME=
# TEST_PASSWORD=
